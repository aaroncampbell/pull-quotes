<?xml version="1.0"?>
<ruleset name="Pull Quotes">
	<description>WordPress Coding Standards for the Pull Quotes plugin.</description>

	<file>pull-quotes.php</file>
	<file>includes</file>

	<arg name="colors" />
	<arg value="sp" />

	<config name="testVersion" value="8.3-" />

	<rule ref="WordPress" />
	<rule ref="PHPCompatibilityWP" />

	<exclude-pattern>*/vendor/*</exclude-pattern>
</ruleset>
